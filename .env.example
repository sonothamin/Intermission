# Intermission — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# OR via CLI: supabase secrets set TMDB_API_KEY=xxx

# TMDB API key (get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key-here

# Allowed origins for CORS (comma-separated, e.g. https://app.intermission.io)
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# These are automatically set by Supabase — only needed for local dev
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
