# Frontend-specific ignores.
# Most rules (node_modules, dist, .env, logs, IDE files) are already
# in the root .gitignore, but we keep the critical build artifacts here
# in case any tool is run with `frontend/` as its CWD.

# Build output
node_modules
dist
dist-ssr
*.local

# Vite cache
.vite

# TypeScript incremental build info
*.tsbuildinfo

# Test/coverage
coverage
*.lcov

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.puku
*.temp*