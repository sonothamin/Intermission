# ─── Editor / tooling scratch ─────────────────────────────────────────────
# Puku AI editor temp files
.puku
*.puku
*.temp*
.temp
.temp/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE / editor directories
.vscode/*
!.vscode/extensions.json
.idea
*.sublime-project
*.sublime-workspace

# ─── Secrets / env (NEVER commit) ────────────────────────────────────────
# Local environment files
.env
.env.*
!.env.example

# Supabase local secrets (CLI writes these outside the repo, but be safe)
.env.local
.env.*.local
supabase/.env
supabase/.env.*

# Deno / Supabase edge function cache & local secrets
supabase/.branches
supabase/.temp
supabase/.env

# Generic secret/key material
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/
*.secret
credentials.json
service-account*.json
gcp-service-account.json
firebase-adminsdk*.json

# ─── Node / JS build outputs ─────────────────────────────────────────────
node_modules/
**/node_modules/
**/dist/
**/dist-ssr/
**/build/
**/.next/
**/.nuxt/
**/.svelte-kit/
**/.cache/
**/.parcel-cache/
**/.turbo/
**/.vercel/

# Root-level npm artifacts: the Supabase CLI is installed here for
# migrations. We track /package.json and /package-lock.json so the CLI
# install is reproducible; only /node_modules is ignored.

# Vite-specific
*.local
.vite/

# TypeScript build info
*.tsbuildinfo

# Coverage / test artifacts
coverage/
**/coverage/
*.lcov
.nyc_output/

# Logs
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
bun-debug.log*

# ─── Misc runtime / OS ───────────────────────────────────────────────────
# History / shell
.history
.bash_history
.zsh_history

# Lockfiles for tools you don't use
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Docker / infra
*.pid
*.seed
*.pid.lock
.docker/

# ─── Workspace-specific ─────────────────────────────────────────────────
# Top-level scratch dirs used during development
scratch/
tmp/
temp/